# Normalize text files to LF while leaving binary files under Git's automatic detection.
* text=auto eol=lf

# Source and configuration files
*.cs text eol=lf
*.csx text eol=lf
*.xaml text eol=lf
*.axaml text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sln text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
