<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.AboutView"
             x:DataType="vm:AboutViewModel">
    <StackPanel Spacing="12">
        <TextBlock Text="{Binding ApplicationName}" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Text="{Binding Version}" />
        <TextBlock Text="{Binding License}" />
        <TextBlock Text="{Binding Acknowledgements}" TextWrapping="Wrap" />
        <TextBlock Text="Project repository (copy to open)" FontWeight="SemiBold" />
        <TextBox Text="{Binding RepositoryAddress}" IsReadOnly="True" AutomationProperties.Name="Project repository address" />
        <TextBlock Text="Documentation (copy to open)" FontWeight="SemiBold" />
        <TextBox Text="{Binding DocumentationAddress}" IsReadOnly="True" AutomationProperties.Name="Documentation address" />
    </StackPanel>
</UserControl>
