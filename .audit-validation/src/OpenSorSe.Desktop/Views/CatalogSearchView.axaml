<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.CatalogSearchView"
             x:DataType="vm:CatalogSearchViewModel">
    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
        <TextBlock Text="Catalog search" FontSize="24" FontWeight="SemiBold" />
        <StackPanel Grid.Row="1" Spacing="6">
            <TextBlock Text="Search saved metadata only" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Searches filenames, stored paths, extensions, deterministic categories, and accepted tags from saved snapshots. This is deterministic metadata search, not semantic search, and it does not read files from disk."
                       TextWrapping="Wrap" />
            <Border Margin="0,4,0,8"
                    Padding="10"
                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="6">
                    <TextBlock Text="Saved searches" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="A saved search stores only its name and query text in OpenSorSe application data. Hits are always recalculated from the current local catalog and are never persisted."
                               TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox PlaceholderText="Saved-search name"
                                 Text="{Binding SavedSearchName, Mode=TwoWay}"
                                 AutomationProperties.Name="Saved-search name" />
                        <Button Grid.Column="1" Content="Save current query" Command="{Binding SaveCurrentSearchCommand}" />
                    </Grid>
                    <TextBlock IsVisible="{Binding HasNoSavedSearches}"
                               Text="No catalog searches are saved."
                               TextWrapping="Wrap" />
                    <ListBox ItemsSource="{Binding SavedSearches}"
                             SelectedItem="{Binding SelectedSavedSearch, Mode=TwoWay}"
                             MaxHeight="150"
                             AutomationProperties.Name="Saved catalog searches">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SavedCatalogSearchRow">
                                <StackPanel Margin="0,3" Spacing="1">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding QueryText, StringFormat=Query: {0}}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding UpdatedAtUtc, StringFormat=Updated: {0:u}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <WrapPanel>
                        <Button Margin="0,0,8,8" Content="Refresh saved searches" Command="{Binding RefreshSavedSearchesCommand}" />
                        <Button Margin="0,0,8,8" Content="Run selected" Command="{Binding RunSelectedSavedSearchCommand}" />
                        <Button Margin="0,0,8,8" Content="Remove selected" Command="{Binding RemoveSelectedSavedSearchCommand}" />
                        <Button Margin="0,0,8,8" Content="Reset saved searches" Command="{Binding RequestResetSavedSearchesCommand}" />
                        <Button IsVisible="{Binding IsSavedSearchResetPending}"
                                Margin="0,0,8,8"
                                Content="Confirm reset"
                                Command="{Binding ConfirmResetSavedSearchesCommand}" />
                        <Button IsVisible="{Binding IsSavedSearchResetPending}"
                                Margin="0,0,8,8"
                                Content="Cancel"
                                Command="{Binding CancelResetSavedSearchesCommand}" />
                    </WrapPanel>
                    <TextBlock Text="{Binding SavedSearchStatusText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox PlaceholderText="Search saved catalog metadata"
                         Text="{Binding QueryText, Mode=TwoWay}"
                         AutomationProperties.Name="Catalog search query" />
                <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}" />
            </Grid>
            <Button Content="Open selected saved snapshot" Command="{Binding OpenSelectedHitCommand}" HorizontalAlignment="Left" />
        </StackPanel>
        <Border Grid.Row="2" Padding="12" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <TextBlock IsVisible="{Binding HasNoHits}" Text="No saved catalog metadata matches this query." TextWrapping="Wrap" />
                <ListBox Grid.Row="1" ItemsSource="{Binding Hits}" SelectedItem="{Binding SelectedHit, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:CatalogSearchHitRow">
                            <StackPanel Margin="0,4" Spacing="2">
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding FullPath}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SnapshotLabel}" />
                                <TextBlock Text="{Binding MatchExplanation}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        <TextBlock Grid.Row="3" Text="{Binding StatusText}" TextWrapping="Wrap" />
    </Grid>
</UserControl>
