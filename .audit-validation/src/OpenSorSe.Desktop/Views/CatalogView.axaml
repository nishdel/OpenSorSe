<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.CatalogView"
             x:DataType="vm:CatalogViewModel">
    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
        <TextBlock Text="Saved catalog" FontSize="24" FontWeight="SemiBold" />
        <StackPanel Grid.Row="1" Spacing="6">
            <TextBlock Text="Optional local review snapshots" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Saved entries contain display-safe metadata and accepted tags stored only in OpenSorSe application data. They are historical snapshots, not live filesystem views, and opening one never changes a file."
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Refresh" Command="{Binding RefreshCommand}" />
                <Button Content="Open selected snapshot" Command="{Binding OpenSelectedCommand}" />
                <Button Content="Remove selected snapshot" Command="{Binding RemoveSelectedCommand}" />
            </StackPanel>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox PlaceholderText="Optional snapshot name; leave blank to clear"
                         Text="{Binding DisplayNameInput, Mode=TwoWay}" />
                <Button Grid.Column="1" Content="Save snapshot name" Command="{Binding SaveDisplayNameCommand}" />
            </Grid>
            <Border Padding="8" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="Catalog maintenance affects only OpenSorSe local catalog data. It never changes scanned folders or files."
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Clear all saved snapshots" Command="{Binding RequestClearAllCommand}" />
                        <Button IsVisible="{Binding IsClearConfirmationPending}" Content="Confirm clear all" Command="{Binding ConfirmClearAllCommand}" />
                        <Button IsVisible="{Binding IsClearConfirmationPending}" Content="Cancel" Command="{Binding CancelClearAllCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
        <Border Grid.Row="2" Padding="12" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
            <Grid RowDefinitions="Auto,*" RowSpacing="8">
                <TextBlock IsVisible="{Binding HasNoEntries}" Text="No saved scan snapshots are available." TextWrapping="Wrap" />
                <ListBox Grid.Row="1" ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:CatalogEntryRow">
                            <StackPanel Margin="0,4" Spacing="2">
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SavedAtUtc, StringFormat=Saved: {0:u}}" />
                                <TextBlock Text="{Binding SourceScope}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        <TextBlock Grid.Row="3" Text="{Binding StatusText}" TextWrapping="Wrap" />
    </Grid>
</UserControl>
