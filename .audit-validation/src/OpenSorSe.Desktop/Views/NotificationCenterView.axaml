<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.NotificationCenterView"
             x:DataType="vm:NotificationCenterViewModel">
    <Border Padding="8" Background="{DynamicResource ThemeControlHighlightMidBrush}" CornerRadius="4" IsVisible="{Binding HasNotifications}">
        <StackPanel Spacing="4">
            <ListBox ItemsSource="{Binding Notifications}" SelectedItem="{Binding SelectedNotification, Mode=TwoWay}" MaxHeight="160">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Button Content="Dismiss selected" Command="{Binding DismissSelectedCommand}" HorizontalAlignment="Right" />
        </StackPanel>
    </Border>
</UserControl>
