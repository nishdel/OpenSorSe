<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:OpenSorSe.Desktop.Views"
        xmlns:vm="clr-namespace:OpenSorSe.Desktop.ViewModels"
        xmlns:ai="clr-namespace:OpenSorSe.Application.AI;assembly=OpenSorSe.Application"
        x:Class="OpenSorSe.Desktop.Views.AiRequestDiagnosticsWindow"
        x:DataType="vm:AiDiagnosticsViewModel"
        Title="AI Request Diagnostics"
        Width="1180" Height="780" MinWidth="850" MinHeight="560"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto" Margin="14">
    <Grid ColumnDefinitions="240,*" ColumnSpacing="14">
      <StackPanel>
        <TextBlock Classes="page-title" Text="AI Request Diagnostics" />
        <TextBlock Classes="page-subtitle" Text="Live, in-memory Ollama request inspection" />
      </StackPanel>
      <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
        <CheckBox Margin="8,0" Content="Auto-scroll" IsChecked="{Binding AutoScroll}" />
        <CheckBox Margin="8,0" Content="Word-wrap" IsChecked="{Binding WordWrap}" Click="OnWordWrapChanged" />
        <Button Margin="8,0,0,0" Content="Copy complete report" Command="{Binding CopyCompleteReportCommand}" />
        <Button Margin="8,0,0,0" Content="Save JSON" Click="OnSaveJson" />
        <Button Margin="8,0,0,0" Content="Save text" Click="OnSaveText" />
      </WrapPanel>
    </Grid>

    <Grid Grid.Row="1" ColumnDefinitions="250,*" ColumnSpacing="14" Margin="0,14,0,10">
      <Border Classes="card">
        <Grid RowDefinitions="Auto,*,Auto">
          <TextBlock FontWeight="SemiBold" Text="Requests (latest 20)" />
          <ListBox Grid.Row="1" Margin="0,8" ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="ai:AiDiagnosticSession">
                <StackPanel Margin="2,5">
                  <TextBlock FontWeight="SemiBold" Text="{Binding OperationType}" />
                  <TextBlock Text="{Binding Status}" />
                  <TextBlock FontSize="11" Text="{Binding RequestId}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <StackPanel Grid.Row="2" Spacing="6">
            <Button Content="Clear current display" Command="{Binding ClearCurrentCommand}" />
            <Button Content="Clear all retained AI diagnostics" Command="{Binding ClearAllCommand}" />
          </StackPanel>
        </Grid>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="10">
        <Border Classes="card">
          <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10">
            <TextBlock Text="{Binding RequestId, StringFormat='Request ID: {0}'}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" Text="{Binding OperationType, StringFormat='Operation: {0}'}" />
            <TextBlock Grid.Column="2" Text="{Binding Model, StringFormat='Model: {0}'}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Row="1" Text="{Binding Endpoint, StringFormat='Endpoint: {0}'}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StartedAt, StringFormat='Started: {0}'}" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Elapsed, StringFormat='Elapsed: {0}'}" />
            <TextBlock Grid.Row="2" Text="{Binding FinalStatus, StringFormat='Status: {0}'}" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding HttpStatus, StringFormat='HTTP: {0}'}" />
            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding CancellationStatus}" />
            <TextBlock Grid.Row="3" Text="{Binding RetryAttempt, StringFormat='Attempt: {0}'}" />
            <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding TransportSummary}" />
          </Grid>
        </Border>

        <TabControl Grid.Row="1">
          <TabItem Header="Overview"><Grid RowDefinitions="Auto,*"><Button HorizontalAlignment="Right" Content="Copy overview" Tag="overview" Click="OnCopySection" /><local:DiagnosticTextBox Grid.Row="1" x:Name="OverviewText" Text="{Binding StageText}" /></Grid></TabItem>
          <TabItem Header="System prompt"><Grid RowDefinitions="Auto,*"><Button HorizontalAlignment="Right" Content="Copy system prompt" Tag="system" Click="OnCopySection" /><local:DiagnosticTextBox Grid.Row="1" x:Name="SystemText" Text="{Binding SystemPrompt}" /></Grid></TabItem>
          <TabItem Header="User prompt"><Grid RowDefinitions="Auto,*"><Button HorizontalAlignment="Right" Content="Copy user prompt" Tag="user" Click="OnCopySection" /><local:DiagnosticTextBox Grid.Row="1" x:Name="UserText" Text="{Binding UserPrompt}" /></Grid></TabItem>
          <TabItem Header="Request JSON"><Grid RowDefinitions="Auto,*"><Button HorizontalAlignment="Right" Content="Copy request JSON" Tag="request" Click="OnCopySection" /><local:DiagnosticTextBox Grid.Row="1" x:Name="RequestText" Text="{Binding RequestJson}" /></Grid></TabItem>
          <TabItem Header="Raw HTTP response"><Grid RowDefinitions="Auto,*"><Button HorizontalAlignment="Right" Content="Copy raw response" Tag="raw" Click="OnCopySection" /><local:DiagnosticTextBox Grid.Row="1" x:Name="RawText" Text="{Binding RawHttpResponse}" /></Grid></TabItem>
          <TabItem Header="Extracted response"><Grid RowDefinitions="Auto,*"><Button HorizontalAlignment="Right" Content="Copy extracted response" Tag="extracted" Click="OnCopySection" /><local:DiagnosticTextBox Grid.Row="1" x:Name="ExtractedText" Text="{Binding ExtractedAssistantResponse}" /></Grid></TabItem>
          <TabItem Header="Parsed response"><Grid RowDefinitions="Auto,*"><Button HorizontalAlignment="Right" Content="Copy parsed response" Tag="parsed" Click="OnCopySection" /><local:DiagnosticTextBox Grid.Row="1" x:Name="ParsedText" Text="{Binding ParsedStructuredResponse}" /></Grid></TabItem>
          <TabItem Header="Validation and errors"><Grid RowDefinitions="Auto,*"><Button HorizontalAlignment="Right" Content="Copy validation error" Tag="validation" Click="OnCopySection" /><local:DiagnosticTextBox Grid.Row="1" x:Name="ValidationTextBox" Text="{Binding ValidationText}" /></Grid></TabItem>
        </TabControl>
      </Grid>
    </Grid>
    <TextBlock Grid.Row="2" Text="{Binding StatusText}" />
  </Grid>
</Window>
