<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.CatalogComparisonView"
             x:DataType="vm:CatalogComparisonViewModel">
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="10">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBlock Text="Compare snapshots" FontSize="24" FontWeight="SemiBold" />
            <Button Grid.Column="1" Content="Help" Command="{Binding HelpCommand}"
                    ToolTip.Tip="Open comparison help" AutomationProperties.Name="Help for Compare snapshots" />
        </Grid>
        <StackPanel Grid.Row="1" Spacing="6">
            <TextBlock Text="Historical stored-metadata comparison" FontSize="18" FontWeight="SemiBold" />
            <TextBlock Text="Compares two saved OpenSorSe snapshots only. It does not open, verify, refresh, or modify any stored file path."
                       TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <StackPanel Spacing="3">
                    <TextBlock Text="Baseline snapshot" />
                    <ComboBox ItemsSource="{Binding Entries}"
                              SelectedItem="{Binding BaselineSelection, Mode=TwoWay}"
                              IsEnabled="{Binding !IsBusy}"
                              AutomationProperties.Name="Baseline snapshot">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:CatalogEntryRow">
                                <TextBlock Text="{Binding Title}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="3">
                    <TextBlock Text="Current snapshot" />
                    <ComboBox ItemsSource="{Binding Entries}"
                              SelectedItem="{Binding CurrentSelection, Mode=TwoWay}"
                              IsEnabled="{Binding !IsBusy}"
                              AutomationProperties.Name="Current snapshot">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:CatalogEntryRow">
                                <TextBlock Text="{Binding Title}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
            <WrapPanel>
                <Button Margin="0,0,8,8" Content="Refresh choices" Command="{Binding RefreshCommand}" />
                <Button Margin="0,0,8,8" Content="Compare selected snapshots" Command="{Binding CompareCommand}" />
                <Button Margin="0,0,8,8" Content="Cancel comparison" Command="{Binding CancelCommand}" />
                <Button Margin="0,0,8,8" Content="Open baseline in Results" Command="{Binding OpenBaselineCommand}" />
                <Button Margin="0,0,8,8" Content="Open current in Results" Command="{Binding OpenCurrentCommand}" />
            </WrapPanel>
            <TextBlock IsVisible="{Binding HasNoEntries}" Text="No saved snapshots are available for comparison." TextWrapping="Wrap" />
        </StackPanel>
        <Border Grid.Row="2" Padding="8" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
            <StackPanel Spacing="5">
                <TextBlock Text="{Binding StatisticsText}" TextWrapping="Wrap" />
                <TextBlock Text="{Binding ScopeStatusText}" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <ComboBox ItemsSource="{Binding Filters}"
                              SelectedItem="{Binding SelectedFilter, Mode=TwoWay}"
                              IsEnabled="{Binding !IsBusy}"
                              MinWidth="130"
                              AutomationProperties.Name="Comparison change filter" />
                    <TextBox Grid.Column="1"
                             PlaceholderText="Filter stored filename or path (maximum 512 characters)"
                             IsEnabled="{Binding !IsBusy}"
                             Text="{Binding FilterText, Mode=TwoWay}"
                             AutomationProperties.Name="Filter comparison rows" />
                </Grid>
            </StackPanel>
        </Border>
        <Border Grid.Row="3" Padding="10" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
            <Grid RowDefinitions="Auto,*" RowSpacing="6">
                <TextBlock IsVisible="{Binding HasNoChanges}" Text="No historical comparison rows match the current state." TextWrapping="Wrap" />
                <ListBox Grid.Row="1" ItemsSource="{Binding Changes}" SelectedItem="{Binding SelectedChange, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:CatalogComparisonChangeRow">
                            <StackPanel Margin="0,4" Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding KindText}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Text="{Binding FullPath}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ChangedFieldsText}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding BaselineDetails, StringFormat=Baseline: {0}}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding CurrentDetails, StringFormat=Current: {0}}" TextWrapping="Wrap" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        <TextBlock Grid.Row="4" Text="{Binding StatusText}" TextWrapping="Wrap" />
    </Grid>
</UserControl>
