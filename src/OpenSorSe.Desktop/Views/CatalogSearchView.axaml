<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             xmlns:views="using:OpenSorSe.Desktop.Views"
             x:Class="OpenSorSe.Desktop.Views.CatalogSearchView"
             x:DataType="vm:CatalogSearchViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <StackPanel Spacing="3">
                    <TextBlock Text="History Search" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="Find files in saved scans using local metadata."
                               TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1"
                        Classes="help"
                        Content="?"
                        Command="{Binding HelpCommand}"
                        ToolTip.Tip="Learn how saved-scan search works"
                        AutomationProperties.Name="Help for saved-scan search" />
            </Grid>

            <Border Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Search saved scans" FontSize="18" FontWeight="SemiBold" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <TextBox Text="{Binding QueryText, Mode=TwoWay}"
                                 PlaceholderText="Filename, path, file type, category, or tag"
                                 AutomationProperties.Name="Search saved scans" />
                        <Button Grid.Column="1"
                                Content="Search"
                                Command="{Binding SearchCommand}"
                                AutomationProperties.Name="Search saved catalog metadata" />
                        <Button Grid.Column="2"
                                Content="Clear"
                                Command="{Binding ClearQueryCommand}"
                                AutomationProperties.Name="Clear catalog search" />
                    </Grid>
                    <views:StatusBanner DataContext="{Binding Status}" />
                </StackPanel>
            </Border>

            <Border Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="Results" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ResultCountText}"
                                   IsVisible="{Binding IsSearchCompleted}"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock IsVisible="{Binding HasNoHits}"
                               Text="No saved scans match this search. Try a filename, file type, category, or tag."
                               TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Polite" />
                    <ListBox ItemsSource="{Binding Hits}"
                             SelectedItem="{Binding SelectedHit, Mode=TwoWay}"
                             IsVisible="{Binding HasSearchResults}"
                             MaxHeight="360"
                             AutomationProperties.Name="Catalog search results">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:CatalogSearchHitRow">
                                <StackPanel Margin="0,5" Spacing="2">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding FullPath}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SnapshotLabel}" />
                                    <TextBlock Text="{Binding MatchExplanation}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Open selected saved scan"
                            Command="{Binding OpenSelectedHitCommand}"
                            IsVisible="{Binding HasSearchResults}"
                            HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="9">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Saved searches" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="Save a useful query for later. Only its name and query text are stored; results are recalculated from the local catalog."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Text="{Binding SavedSearchName, Mode=TwoWay}"
                                 PlaceholderText="Name this search"
                                 AutomationProperties.Name="New saved-search name" />
                        <Button Grid.Column="1"
                                Content="Save current search"
                                Command="{Binding SaveCurrentSearchCommand}" />
                    </Grid>
                    <TextBlock IsVisible="{Binding HasNoSavedSearches}"
                               Text="No saved searches yet."
                               TextWrapping="Wrap" />
                    <ListBox ItemsSource="{Binding SavedSearches}"
                             SelectedItem="{Binding SelectedSavedSearch, Mode=TwoWay}"
                             MaxHeight="220"
                             AutomationProperties.Name="Saved catalog searches">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:SavedCatalogSearchRow">
                                <StackPanel Margin="0,4" Spacing="2">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding QueryText, StringFormat=Query: {0}}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding UpdatedAtUtc, StringFormat=Updated: {0:u}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Spacing="8" IsVisible="{Binding HasSelectedSavedSearch}">
                        <WrapPanel>
                            <Button Margin="0,0,8,8"
                                    Content="Run selected search"
                                    Command="{Binding RunSelectedSavedSearchCommand}" />
                            <Button Margin="0,0,8,8"
                                    Content="Remove selected search"
                                    Command="{Binding RemoveSelectedSavedSearchCommand}" />
                        </WrapPanel>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <TextBox Text="{Binding SavedSearchRenameText, Mode=TwoWay}"
                                     PlaceholderText="New saved-search name"
                                     AutomationProperties.Name="Rename selected saved search" />
                            <Button Grid.Column="1"
                                    Content="Rename"
                                    Command="{Binding RenameSelectedSavedSearchCommand}" />
                        </Grid>
                    </StackPanel>
                    <WrapPanel>
                        <Button Margin="0,0,8,8"
                                Content="Reload saved searches"
                                Command="{Binding RefreshSavedSearchesCommand}" />
                        <Button Margin="0,0,8,8"
                                Content="Clear all saved searches"
                                Command="{Binding RequestResetSavedSearchesCommand}" />
                        <Button IsVisible="{Binding IsSavedSearchResetPending}"
                                Margin="0,0,8,8"
                                Content="Confirm clear all"
                                Command="{Binding ConfirmResetSavedSearchesCommand}" />
                        <Button IsVisible="{Binding IsSavedSearchResetPending}"
                                Margin="0,0,8,8"
                                Content="Cancel"
                                Command="{Binding CancelResetSavedSearchesCommand}" />
                    </WrapPanel>
                    <TextBlock Text="{Binding SavedSearchStatusText}"
                               TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Polite" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
