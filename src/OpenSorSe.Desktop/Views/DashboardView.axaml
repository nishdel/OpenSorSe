<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <ScrollViewer>
        <StackPanel Spacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock Text="Dashboard" FontSize="24" FontWeight="SemiBold" />
                <Button Grid.Column="1" Content="Help" Command="{Binding HelpCommand}"
                        ToolTip.Tip="Open Dashboard help" AutomationProperties.Name="Help for Dashboard" />
            </Grid>
            <TextBlock Text="{Binding StatusText}" />
            <Border IsVisible="{Binding IsAwaitingFirstScan}"
                    Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                    BorderThickness="1">
                <TextBlock Text="Choose a folder and complete a scan to see its latest results here. OpenSorSe does not organize or modify files in v0.1."
                           TextWrapping="Wrap" />
            </Border>
            <StackPanel Spacing="4">
                <TextBlock Text="Latest completed scan" FontSize="18" FontWeight="SemiBold" />
                <TextBlock Text="{Binding Statistics.FilesScanned, StringFormat='Files scanned: {0}'}" />
                <TextBlock Text="{Binding Statistics.FoldersDiscovered, StringFormat='Folders discovered: {0}'}" />
                <TextBlock Text="{Binding Statistics.ExactDuplicates, StringFormat='Exact duplicate files: {0}'}" />
                <TextBlock Text="{Binding Statistics.Warnings, StringFormat='Warnings: {0}'}" />
            </StackPanel>
            <StackPanel Spacing="8">
                <TextBlock Text="Quick actions" FontSize="18" FontWeight="SemiBold" />
                <Button Command="{Binding ScanFolderCommand}" Content="Scan folder" />
                <Button Command="{Binding ViewResultsCommand}"
                        Content="View results"
                        ToolTip.Tip="Available after a scan completes in this application session." />
                <Button Command="{Binding OpenSettingsCommand}" Content="Settings" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
