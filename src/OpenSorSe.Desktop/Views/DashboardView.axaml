<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="18">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <StackPanel Spacing="3">
                    <TextBlock Classes="page-title" Text="Home" />
                    <TextBlock Classes="page-subtitle" Text="Find clarity in your files." />
                </StackPanel>
                <Button Grid.Column="1"
                        Classes="help"
                        Content="?"
                        Command="{Binding HelpCommand}"
                        ToolTip.Tip="Learn what Home shows and how OpenSorSe keeps source files safe."
                        AutomationProperties.Name="Help for Home" />
            </Grid>

            <Border IsVisible="{Binding IsAwaitingFirstScan}" Classes="empty-state">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="O"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{DynamicResource AccentPrimaryBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Ready for your first scan"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Choose a folder and see what is inside. Your files stay where they are."
                               Classes="page-subtitle"
                               TextAlignment="Center" />
                    <Button Classes="primary"
                            Content="Scan a folder"
                            HorizontalAlignment="Center"
                            Command="{Binding ScanFolderCommand}" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding HasCompletedScan}" Classes="card">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Latest scan" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="A compact view of the latest scan in this session."
                                       Classes="page-subtitle" />
                        </StackPanel>
                        <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Margin="0,0,8,0"
                                    Classes="primary"
                                    Content="View files"
                                    Command="{Binding ViewResultsCommand}" />
                            <Button Classes="secondary"
                                    Content="Scan another folder"
                                    Command="{Binding ScanFolderCommand}" />
                        </WrapPanel>
                    </Grid>
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                        <Border Classes="metric-tile"
                                BorderBrush="{DynamicResource AccentPrimaryBrush}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Files discovered" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Statistics.FilesScanned}" FontSize="26" />
                                <TextBlock Text="Files included in the scan" Classes="page-subtitle" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1"
                                Classes="metric-tile"
                                BorderBrush="{DynamicResource AccentOrganizationBrush}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Folders explored" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Statistics.FoldersDiscovered}" FontSize="26" />
                                <TextBlock Text="Folders checked locally" Classes="page-subtitle" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Classes="metric-tile"
                                BorderBrush="{DynamicResource AccentDuplicateBrush}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Copies spotted" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Statistics.ExactDuplicates}" FontSize="26" />
                                <TextBlock Text="Exact duplicate files found" Classes="page-subtitle" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3"
                                Classes="metric-tile"
                                BorderBrush="{DynamicResource WarningBrush}">
                            <StackPanel Spacing="3">
                                <TextBlock Text="Needs attention" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Statistics.Warnings}" FontSize="26" />
                                <TextBlock Text="Warnings from this scan" Classes="page-subtitle" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <StackPanel Spacing="3">
                        <TextBlock Text="What would you like to do?" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock Text="Start a new scan or adjust how OpenSorSe works."
                                   Classes="page-subtitle" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Margin="0,0,8,0"
                                Classes="primary"
                                Content="Scan folder"
                                Command="{Binding ScanFolderCommand}" />
                        <Button Classes="secondary"
                                Content="Settings"
                                Command="{Binding OpenSettingsCommand}" />
                    </WrapPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
