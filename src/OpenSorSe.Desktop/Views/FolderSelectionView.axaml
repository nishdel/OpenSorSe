<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.FolderSelectionView"
             x:DataType="vm:FolderSelectionViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock Text="Folder Selection" FontSize="24" FontWeight="SemiBold" />
                <Button Grid.Column="1" Content="Help" Command="{Binding HelpCommand}"
                        ToolTip.Tip="Open scan-folder help" AutomationProperties.Name="Help for Scan folders" />
            </Grid>
            <TextBlock Text="Add accessible local folders, then start a read-only analysis. OpenSorSe does not modify selected files."
                       TextWrapping="Wrap" />
            <TextBlock Text="Selected folders" FontWeight="SemiBold" />
            <ListBox ItemsSource="{Binding SelectedFolders}"
                     SelectedItem="{Binding SelectedFolder, Mode=TwoWay}"
                     MinHeight="120" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Width="420"
                         PlaceholderText="Absolute folder path"
                         Text="{Binding FolderPathInput, Mode=TwoWay}" />
                <Button Content="Browse..." Click="OnBrowseClick" />
                <Button Content="Add folder" Command="{Binding AddFolderCommand}" />
                <Button Content="Remove selected" Command="{Binding RemoveSelectedFolderCommand}" />
            </StackPanel>
            <TextBlock Text="Recent locations" FontWeight="SemiBold" />
            <ListBox ItemsSource="{Binding RecentFolders}" MaxHeight="100" />
            <Button Content="Start scan" Command="{Binding StartScanCommand}" HorizontalAlignment="Left" />
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
