<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.LogViewerView"
             x:DataType="vm:LogViewerViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12">
            <TextBlock Text="Diagnostics" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="This page reports the health of OpenSorSe's own application logging. It does not inspect selected folders or change user files."
                       TextWrapping="Wrap" />
            <Border Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Logging status" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LoggingStatus}" TextWrapping="Wrap" />
                    <TextBlock Text="Recorded events" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding RecordedEventCount}" FontSize="18" />
                    <TextBlock Text="The number of OpenSorSe diagnostic events recorded during this application session."
                               TextWrapping="Wrap" />
                    <TextBlock Text="Log write failures" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Statistics.FileWriteFailures}" FontSize="18" />
                    <TextBlock Text="The number of times OpenSorSe could not write one of its own diagnostic log entries."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <TextBlock IsVisible="{Binding IsEmpty}" Text="{Binding EmptyStateMessage}" TextWrapping="Wrap" />
            <Button Content="Refresh diagnostics" Command="{Binding RefreshCommand}" />
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
