<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
        xmlns:views="using:OpenSorSe.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="650"
        x:Class="OpenSorSe.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="OpenSorSe"
        MinWidth="960"
        MinHeight="640">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto"
          ColumnDefinitions="220,*">
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Padding="12"
                BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="OpenSorSe" FontSize="20" FontWeight="SemiBold" />
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Padding="8"
                BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                BorderThickness="0,0,1,0">
            <ListBox ItemsSource="{Binding Destinations}"
                     SelectedItem="{Binding SelectedDestination, Mode=TwoWay}" />
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Padding="24">
            <Grid>
                <Grid IsVisible="{Binding IsDashboardSelected}">
                    <views:DashboardView DataContext="{Binding Dashboard}" />
                </Grid>
                <Grid IsVisible="{Binding IsScanSelected}">
                    <Grid IsVisible="{Binding IsFolderSelectionVisible}">
                        <views:FolderSelectionView DataContext="{Binding FolderSelection}" />
                    </Grid>
                    <Grid IsVisible="{Binding IsProcessing}">
                        <views:ScanProgressView DataContext="{Binding ScanProgress}" />
                    </Grid>
                </Grid>
                <Grid IsVisible="{Binding IsResultsSelected}">
                    <views:ResultsView DataContext="{Binding Results}" />
                </Grid>
                <Grid IsVisible="{Binding IsRulesSelected}">
                    <views:RuleEditorView DataContext="{Binding RuleEditor}" />
                </Grid>
                <Grid IsVisible="{Binding IsSettingsSelected}">
                    <views:SettingsView DataContext="{Binding Settings}" />
                </Grid>
                <Grid IsVisible="{Binding IsDiagnosticsSelected}">
                    <views:LogViewerView DataContext="{Binding LogViewer}" />
                </Grid>
                <Grid IsVisible="{Binding IsHistorySelected}">
                    <views:UndoHistoryView DataContext="{Binding UndoHistory}" />
                </Grid>
                <Grid IsVisible="{Binding IsAboutSelected}">
                    <views:AboutView DataContext="{Binding About}" />
                </Grid>
                <views:NotificationCenterView DataContext="{Binding Notifications}"
                                              VerticalAlignment="Top"
                                              HorizontalAlignment="Right"
                                              Width="360" />
                <StackPanel IsVisible="{Binding IsFeaturePageSelected}"
                            Spacing="8">
                    <TextBlock Text="{Binding CurrentPageTitle}" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="This application shell hosts the selected feature page." TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Padding="8"
                BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" />
        </Border>
    </Grid>

</Window>
