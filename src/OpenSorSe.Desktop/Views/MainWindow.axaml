<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
        xmlns:views="using:OpenSorSe.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1180"
        d:DesignHeight="760"
        x:Class="OpenSorSe.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/opensorse-app-icon.png"
        Title="{x:Static vm:DesktopBranding.ProductName}"
        MinWidth="980"
        MinHeight="660">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto"
          ColumnDefinitions="252,*">
        <Border Grid.Row="0"
                Grid.Column="0"
                Padding="14,18,14,12"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="18">
                <Grid ColumnDefinitions="64,*"
                      ColumnSpacing="10"
                      AutomationProperties.Name="OpenSorSe, Open Sort and Search">
                    <Image Width="64"
                           Height="64"
                           Source="/Assets/opensorse-app-icon.png"
                           Stretch="Uniform"
                           VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static vm:DesktopBranding.ProductName}"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{x:Static vm:DesktopBranding.ExpandedName}"
                                   FontSize="9"
                                   FontWeight="SemiBold"
                                   LetterSpacing="1.1"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="{x:Static vm:DesktopBranding.Tagline}"
                                   Margin="0,3,0,0"
                                   FontSize="10"
                                   Foreground="{DynamicResource AccentOrganizationBrush}" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="12">
                        <ItemsControl ItemsSource="{Binding PrimaryNavigationItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:NavigationItem">
                                    <Button Classes="nav-item"
                                            Classes.active="{Binding IsSelected}"
                                            Click="OnNavigationButtonClick">
                                        <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                                            <TextBlock Text="{Binding Icon}"
                                                       Foreground="{DynamicResource AccentPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Label}" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel IsVisible="{Binding HasAdvancedNavigationItems}" Spacing="4">
                            <TextBlock Text="ADVANCED"
                                       Margin="10,8,0,2"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                            <ItemsControl ItemsSource="{Binding AdvancedNavigationItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:NavigationItem">
                                        <Button Classes="nav-item"
                                                Classes.active="{Binding IsSelected}"
                                                Click="OnNavigationButtonClick">
                                            <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                                                <TextBlock Text="{Binding Icon}"
                                                           Foreground="{DynamicResource AccentOrganizationBrush}"
                                                           HorizontalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Label}" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ItemsControl Grid.Row="2" ItemsSource="{Binding FooterNavigationItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavigationItem">
                            <Button Classes="nav-item"
                                    Classes.active="{Binding IsSelected}"
                                    Click="OnNavigationButtonClick">
                                <Grid ColumnDefinitions="24,*" ColumnSpacing="8">
                                    <TextBlock Text="{Binding Icon}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding Label}" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Padding="22"
                Background="{DynamicResource BackgroundBaseBrush}">
            <Grid>
                <Grid IsVisible="{Binding IsDashboardSelected}">
                    <views:DashboardView DataContext="{Binding Dashboard}" />
                </Grid>
                <Grid IsVisible="{Binding IsScanSelected}">
                    <Grid IsVisible="{Binding IsFolderSelectionVisible}">
                        <views:FolderSelectionView DataContext="{Binding FolderSelection}" />
                    </Grid>
                    <Grid IsVisible="{Binding IsProcessing}">
                        <views:ScanProgressView DataContext="{Binding ScanProgress}" />
                    </Grid>
                </Grid>
                <Grid IsVisible="{Binding IsFilesAreaSelected}">
                    <views:ResultsView DataContext="{Binding Results}" />
                </Grid>
                <Grid IsVisible="{Binding IsSavedScansAreaSelected}" RowDefinitions="Auto,*" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="3">
                            <TextBlock Classes="page-title" Text="Saved scans" />
                            <TextBlock Classes="page-subtitle"
                                        Text="Return to previous scans anytime." />
                        </StackPanel>
                        <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Margin="0,0,6,0"
                                    Classes="secondary"
                                    Content="Scan Library"
                                    Command="{Binding ShowSavedScanLibraryCommand}" />
                            <Button Margin="0,0,6,0"
                                    Classes="secondary"
                                    Content="Search saved scans"
                                    Command="{Binding ShowSavedScanSearchCommand}" />
                            <Button Classes="secondary"
                                    Content="Compare scans"
                                    IsVisible="{Binding IsCompareScansAvailable}"
                                    Command="{Binding ShowSavedScanComparisonCommand}" />
                        </WrapPanel>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid IsVisible="{Binding IsSavedScanLibrarySelected}">
                            <views:CatalogView DataContext="{Binding Catalog}" />
                        </Grid>
                        <Grid IsVisible="{Binding IsSavedScanSearchSelected}">
                            <views:CatalogSearchView DataContext="{Binding CatalogSearch}" />
                        </Grid>
                        <Grid IsVisible="{Binding IsSavedScanComparisonSelected}">
                            <views:CatalogComparisonView DataContext="{Binding CatalogComparison}" />
                        </Grid>
                    </Grid>
                </Grid>
                <Grid IsVisible="{Binding IsSemanticSearchSelected}" RowDefinitions="Auto,*" RowSpacing="10">
                    <Button Classes="secondary"
                            Content="Back to Files"
                            HorizontalAlignment="Left"
                            Command="{Binding BackToFilesCommand}" />
                    <views:SemanticSearchView Grid.Row="1" DataContext="{Binding SemanticSearch}" />
                </Grid>
                <Grid IsVisible="{Binding IsStructureHistorySelected}">
                    <views:StructureHistoryView DataContext="{Binding StructureHistory}" />
                </Grid>
                <Grid IsVisible="{Binding IsRulesSelected}">
                    <views:RuleEditorView DataContext="{Binding RuleEditor}" />
                </Grid>
                <Grid IsVisible="{Binding IsSettingsSelected}">
                    <views:SettingsView DataContext="{Binding Settings}" />
                </Grid>
                <Grid IsVisible="{Binding IsDiagnosticsSelected}">
                    <views:LogViewerView DataContext="{Binding LogViewer}" />
                </Grid>
                <Grid IsVisible="{Binding IsHistorySelected}">
                    <views:UndoHistoryView DataContext="{Binding UndoHistory}" />
                </Grid>
                <Grid IsVisible="{Binding IsHelpSelected}">
                    <views:HelpView DataContext="{Binding Help}" />
                </Grid>
                <Grid IsVisible="{Binding IsAboutSelected}">
                    <views:AboutView DataContext="{Binding About}" />
                </Grid>
                <views:NotificationCenterView DataContext="{Binding Notifications}"
                                              VerticalAlignment="Top"
                                              HorizontalAlignment="Right"
                                              Width="360" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Classes="status-bar">
            <Grid ColumnDefinitions="Auto,*,160,Auto" ColumnSpacing="10">
                <Border Width="9"
                        Height="9"
                        Classes="status-indicator"
                        Classes.active="{Binding IsGlobalOperationActive}"
                        Classes.error="{Binding IsGlobalStatusError}"
                        CornerRadius="5"
                        VerticalAlignment="Center" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding GlobalStatusText}" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding GlobalStatusDetail}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <ProgressBar Grid.Column="2"
                             IsVisible="{Binding IsGlobalOperationActive}"
                             Minimum="0"
                             Maximum="1"
                             Value="{Binding GlobalProgressValue}"
                             IsIndeterminate="{Binding IsGlobalProgressIndeterminate}"
                             VerticalAlignment="Center" />
                <Button Grid.Column="3"
                        IsVisible="{Binding CanCancelCurrentOperation}"
                        Classes="secondary"
                        Content="Cancel"
                        Command="{Binding CancelCurrentOperationCommand}" />
            </Grid>
        </Border>
    </Grid>
</Window>
