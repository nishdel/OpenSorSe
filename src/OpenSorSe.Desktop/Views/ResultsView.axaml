<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             xmlns:ai="using:OpenSorSe.Application.AI"
             xmlns:content="using:OpenSorSe.Application.Content"
             xmlns:views="using:OpenSorSe.Desktop.Views"
             x:Class="OpenSorSe.Desktop.Views.ResultsView"
             x:DataType="vm:ResultsViewModel">
    <UserControl.KeyBindings>
        <KeyBinding Gesture="Escape" Command="{Binding DuplicateReview.CloseDrawerCommand}" />
    </UserControl.KeyBindings>

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <StackPanel Spacing="4">
                <TextBlock Text="Results" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Review only — this page does not move, rename, or delete files."
                           TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Duplicate View"
                        Command="{Binding OpenDuplicateReviewCommand}"
                        IsEnabled="{Binding CanOpenDuplicateReview}" />
                <Button Content="Help"
                        Command="{Binding HelpCommand}"
                        ToolTip.Tip="Open Results help"
                        AutomationProperties.Name="Help for Results" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="12">
            <Border Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                    BorderThickness="1"
                    AutomationProperties.Name="Fixed Results filters">
                <Grid ColumnDefinitions="*,*,*,*,Auto"
                      RowDefinitions="Auto,Auto"
                      ColumnSpacing="8"
                      RowSpacing="8">
                    <TextBox Grid.Column="0"
                             PlaceholderText="Search name, path, type, category, or tags"
                             Text="{Binding QueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding AvailableDuplicateFilters}"
                              SelectedItem="{Binding SelectedDuplicateFilter, Mode=TwoWay}" />
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding ExtensionOptions}"
                              SelectedItem="{Binding SelectedExtensionOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ResultsExtensionFilterOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox Grid.Column="3"
                              ItemsSource="{Binding CategoryOptions}"
                              SelectedItem="{Binding SelectedCategoryOption, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ResultsCategoryFilterOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="4"
                            Content="Clear filters"
                            Command="{Binding ClearFiltersCommand}" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="0"
                              ItemsSource="{Binding AvailablePlannedOperationFilters}"
                              SelectedItem="{Binding SelectedPlannedOperationFilter, Mode=TwoWay}" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="1"
                              ItemsSource="{Binding AvailableSortFields}"
                              SelectedItem="{Binding SelectedSortField, Mode=TwoWay}" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="2"
                              ItemsSource="{Binding AvailableSortDirections}"
                              SelectedItem="{Binding SelectedSortDirection, Mode=TwoWay}" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="3"
                              ItemsSource="{Binding AvailablePageSizes}"
                              SelectedItem="{Binding SelectedPageSize, Mode=TwoWay}" />
                    <StackPanel Grid.Row="1"
                                Grid.Column="4"
                                Orientation="Horizontal"
                                Spacing="6">
                        <ProgressBar IsIndeterminate="True"
                                     Width="36"
                                     Height="4"
                                     IsVisible="{Binding IsLoading}" />
                        <TextBlock Text="{Binding PageRangeText}" VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          IsVisible="{Binding IsExplorerVisible}"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <Border IsVisible="{Binding HasNoSnapshot}"
                            Padding="12"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1">
                        <TextBlock Text="No completed scan results are available. Return to Scan to start a read-only scan."
                                   TextWrapping="Wrap" />
                    </Border>
                    <Border IsVisible="{Binding IsEmptyCompletedScan}"
                            Padding="12"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1">
                        <TextBlock Text="This completed scan found no files."
                                   TextWrapping="Wrap" />
                    </Border>
                    <Border IsVisible="{Binding HasSnapshot}"
                            Padding="12"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding ActiveQueryDescription}" TextWrapping="Wrap" />
                            <TextBlock IsVisible="{Binding HasNoFilterResults}"
                                       Text="No files match the active filters."
                                       TextWrapping="Wrap" />
                            <Grid ColumnDefinitions="2*,3*,Auto,Auto,Auto,Auto,Auto,2*" ColumnSpacing="12">
                                <TextBlock Text="Name" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="Path" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="2" Text="Type" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="3" Text="Size" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="4" Text="Modified" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="5" Text="Duplicate" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="6" Text="Planned" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="7" Text="Tags" FontWeight="SemiBold" />
                            </Grid>
                            <ListBox ItemsSource="{Binding PageRows}"
                                     SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                                     AutomationProperties.Name="Result rows">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ResultsFileRow">
                                        <Border Padding="0,6"
                                                BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                                                BorderThickness="0,1,0,0">
                                            <Grid ColumnDefinitions="2*,3*,Auto,Auto,Auto,Auto,Auto,2*" ColumnSpacing="12">
                                                <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding FullPath}" />
                                                <TextBlock Grid.Column="1" Text="{Binding FullPath}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding FullPath}" />
                                                <TextBlock Grid.Column="2" Text="{Binding Extension}" />
                                                <TextBlock Grid.Column="3" Text="{Binding Size}" />
                                                <TextBlock Grid.Column="4" Text="{Binding ModifiedTime}" />
                                                <TextBlock Grid.Column="5" Text="{Binding DuplicateStatus}" />
                                                <TextBlock Grid.Column="6" Text="{Binding PlannedOperation}" />
                                                <TextBlock Grid.Column="7" Text="{Binding Tags}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding MatchExplanation}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                <Button Content="Previous" Command="{Binding PreviousPageCommand}" />
                                <TextBlock Text="{Binding PageRangeText}" VerticalAlignment="Center" />
                                <Button Content="Next" Command="{Binding NextPageCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border IsVisible="{Binding HasSelectedDetails}"
                            Padding="12"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Selected file (read-only)" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedDetails.FileName}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedDetails.FullPath}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedDetails.Classification}" />
                            <TextBlock Text="{Binding SelectedDetails.DuplicateStatus}" />
                            <TextBlock Text="{Binding SelectedDetails.Tags, StringFormat=Tags: {0}}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SelectedRow.MatchExplanation, StringFormat=Search match: {0}}" TextWrapping="Wrap" />
                            <TextBlock Text="Extracted metadata" FontWeight="SemiBold" Margin="0,5,0,0" />
                            <TextBlock Text="{Binding ContentDetailsStatus}" TextWrapping="Wrap" />
                            <ItemsControl IsVisible="{Binding HasContentMetadata}"
                                          ItemsSource="{Binding ContentMetadata}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="content:ExtractedMetadataField">
                                        <Grid ColumnDefinitions="*,2*,*" ColumnSpacing="8" Margin="0,2">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="2" Text="{Binding Provenance}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBox Text="{Binding UserTagText, Mode=TwoWay}"
                                         PlaceholderText="Comma-separated local tags" />
                                <Button Grid.Column="1" Content="Add tags" Command="{Binding AddUserTagsCommand}" />
                            </Grid>
                            <ListBox ItemsSource="{Binding UserTags}"
                                     SelectedItem="{Binding SelectedUserTag, Mode=TwoWay}"
                                     MaxHeight="140">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ResultTagRow">
                                        <Grid ColumnDefinitions="2*,*,*,*" ColumnSpacing="8" Margin="0,2">
                                            <TextBlock Text="{Binding DisplayName}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Category}" />
                                            <TextBlock Grid.Column="2" Text="{Binding Source}" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding AcceptanceState}"
                                                       ToolTip.Tip="{Binding Explanation}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Content="Remove selected tag"
                                    Command="{Binding RemoveSelectedTagCommand}"
                                    HorizontalAlignment="Left" />
                            <WrapPanel>
                                <Button Margin="0,0,8,0"
                                        Content="Accept suggestion"
                                        Command="{Binding AcceptSuggestedTagCommand}" />
                                <Button Content="Reject suggestion"
                                        Command="{Binding RejectSuggestedTagCommand}" />
                            </WrapPanel>
                            <TextBlock Text="{Binding UserTagStatusText}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border IsVisible="{Binding IsVisible}"
                            Padding="12"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1"
                            DataContext="{Binding AiSuggestions}"
                            x:DataType="vm:AiSuggestionsViewModel">
                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Optional AI suggestions" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="AI output is unverified and preview-only. No suggestion changes a file or folder."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        IsVisible="{Binding IsBusy}"
                                        Content="Cancel"
                                        Command="{Binding CancelAiOperationCommand}" />
                                <Button Grid.Column="2" Content="Help" Command="{Binding HelpCommand}" />
                            </Grid>
                            <views:StatusBanner DataContext="{Binding Status}" />
                            <Border IsVisible="{Binding IsFileRenameVisible}"
                                    Padding="8"
                                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="AI file-rename suggestion" FontWeight="SemiBold" />
                                    <Button Content="Suggest a name for the selected file" Command="{Binding GenerateSuggestionCommand}" />
                                    <StackPanel IsVisible="{Binding HasRenameSuggestion}" Spacing="4">
                                        <TextBox Text="{Binding ProposedFileName, Mode=TwoWay}" />
                                        <TextBlock Text="{Binding RenameReason}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding RenameConfidenceText}" TextWrapping="Wrap" />
                                        <WrapPanel>
                                            <Button Margin="0,0,8,0" Content="Record accept or edit" Command="{Binding AcceptRenameCommand}" />
                                            <Button Content="Reject suggestion" Command="{Binding RejectRenameCommand}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border IsVisible="{Binding IsFolderStructureVisible}"
                                    Padding="8"
                                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="AI folder-structure suggestion" FontWeight="SemiBold" />
                                    <WrapPanel>
                                        <Button Margin="0,0,8,0" Content="Suggest structure for this page" Command="{Binding GenerateFolderStructureCommand}" />
                                        <Button Margin="0,0,8,0" Content="Record acceptance" Command="{Binding AcceptFolderStructureCommand}" />
                                        <Button Content="Reject suggestion" Command="{Binding RejectFolderStructureCommand}" />
                                    </WrapPanel>
                                    <ItemsControl IsVisible="{Binding HasFolderStructurePlan}" ItemsSource="{Binding StructureItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="ai:AiFolderStructurePlanItem">
                                                <Grid ColumnDefinitions="2*,3*" ColumnSpacing="8">
                                                    <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Text="{Binding DestinationFolder}" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Padding="12"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Warnings and limitations" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock IsVisible="{Binding HasNoWarnings}" Text="No scan warnings were reported." />
                            <ItemsControl IsVisible="{Binding HasWarnings}" ItemsSource="{Binding Warnings}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="1"
                  IsVisible="{Binding IsDuplicateReviewVisible}">
                <Grid DataContext="{Binding DuplicateReview}"
                      x:DataType="vm:DuplicateReviewViewModel"
                      x:Name="DuplicateViewRoot"
                      RowDefinitions="Auto,Auto,*"
                      RowSpacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Duplicate View" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Select a group to open its read-only details in the right drawer."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="Back to Results" Command="{Binding BackToExplorerCommand}" />
                    <Button Grid.Column="2" Content="Help" Command="{Binding HelpCommand}" />
                </Grid>
                <TextBox Grid.Row="1"
                         PlaceholderText="Filter by filename, folder, type, or category"
                         Text="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AutomationProperties.Name="Filter duplicate groups" />
                <Grid Grid.Row="2" ColumnDefinitions="2*,3*" ColumnSpacing="12">
                    <Border Padding="12"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1">
                        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
                            <TextBlock Text="Duplicate groups" FontSize="18" FontWeight="SemiBold" />
                            <views:StatusBanner Grid.Row="1" DataContext="{Binding Status}" />
                            <ListBox Grid.Row="2"
                                     ItemsSource="{Binding VisibleGroupRows}"
                                     SelectedItem="{Binding SelectedGroupRow, Mode=TwoWay}"
                                     AutomationProperties.Name="Duplicate groups">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:DuplicateReviewGroupRow">
                                        <StackPanel Margin="0,5" Spacing="2">
                                            <TextBlock Text="{Binding Group.Ordinal, StringFormat=Group {0}}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Group.MemberCount, StringFormat={}{0} identical files}" />
                                            <TextBlock Text="{Binding CommonFileSize, StringFormat=Each file: {0}}" />
                                            <TextBlock Text="{Binding MemberSummary}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1"
                            IsVisible="{Binding IsDrawerOpen}"
                            Padding="12"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1"
                            AutomationProperties.Name="Duplicate details drawer">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <TextBlock Text="{Binding SelectedGroupCountText}" FontSize="18" FontWeight="SemiBold" />
                                <Button Grid.Column="1"
                                        Content="Close"
                                        Command="{Binding CloseDrawerCommand}"
                                        AutomationProperties.Name="Close duplicate details" />
                            </Grid>
                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="9">
                                    <TextBlock Text="Review only. Duplicate View does not delete, move, rename, or modify files."
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedGroupCommonSizeText, StringFormat=Each file: {0}}" />
                                    <TextBlock Text="{Binding SelectedGroupPotentialReclaimableText, StringFormat=Possible space saved by keeping one copy: {0}}"
                                               TextWrapping="Wrap" />
                                    <ItemsControl ItemsSource="{Binding MemberRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:DuplicateFileRow">
                                                <Border Padding="0,7"
                                                        BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                                                        BorderThickness="0,1,0,0">
                                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  VerticalAlignment="Top"
                                                                  AutomationProperties.Name="Select duplicate file" />
                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding ParentPath}" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding SizeText}" />
                                                            <WrapPanel>
                                                                <Button Margin="0,2,8,0"
                                                                        Content="Open file"
                                                                        Command="{Binding DataContext.OpenFileCommand, ElementName=DuplicateViewRoot}"
                                                                        CommandParameter="{Binding}"
                                                                        x:CompileBindings="False" />
                                                                <Button Margin="0,2,8,0"
                                                                        Content="Open containing folder"
                                                                        Command="{Binding DataContext.OpenContainingFolderCommand, ElementName=DuplicateViewRoot}"
                                                                        CommandParameter="{Binding}"
                                                                        x:CompileBindings="False" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="{Binding SelectedMemberCountText}"
                                               IsVisible="{Binding IsLargeGroup}"
                                               TextWrapping="Wrap" />
                                    <WrapPanel>
                                        <Button IsVisible="{Binding IsExactPair}" Margin="0,0,8,8" Content="Open both files" Command="{Binding OpenBothFilesCommand}" />
                                        <Button IsVisible="{Binding IsLargeGroup}" Margin="0,0,8,8" Content="Open selected files" Command="{Binding OpenSelectedFilesCommand}" />
                                        <Button Margin="0,0,8,8" Content="Open selected containing folders" Command="{Binding OpenSelectedFoldersCommand}" />
                                        <Button IsVisible="{Binding IsOpening}" Margin="0,0,8,8" Content="Cancel opening" Command="{Binding CancelOpenCommand}" />
                                        <Button Margin="0,0,8,8" Content="Show group in Results" Command="{Binding ShowGroupFilesCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1"
                            IsVisible="{Binding !IsDrawerOpen}"
                            Padding="24"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1">
                        <TextBlock Text="Select a duplicate group to review its locations. The group list remains visible while the drawer is open."
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Border>
                </Grid>
            </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Padding="8"
                BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</UserControl>
