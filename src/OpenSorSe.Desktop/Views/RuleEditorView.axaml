<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.RuleEditorView"
             x:DataType="vm:RuleEditorViewModel">
    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,*,Auto" ColumnSpacing="16" RowSpacing="12">
        <Grid Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <StackPanel>
                <TextBlock Text="Sorting Recipes" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Define repeatable ways to classify files." Classes="page-subtitle" />
            </StackPanel>
            <Button Grid.Column="1" Classes="help" Content="?" Command="{Binding HelpCommand}"
                    ToolTip.Tip="Open Sorting rules help" AutomationProperties.Name="Help for Sorting rules" />
        </Grid>
        <TextBlock Grid.Row="1" Grid.ColumnSpan="2"
                   Text="The current desktop does not create, persist, or execute rules. This surface only reviews rule data supplied in memory."
                   TextWrapping="Wrap" />
        <StackPanel Grid.Row="2" Spacing="6">
            <TextBlock Text="Current rules" FontWeight="SemiBold" />
            <TextBlock IsVisible="{Binding IsEmpty}" Text="{Binding EmptyStateMessage}" TextWrapping="Wrap" />
            <ListBox IsVisible="{Binding HasRules}" ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule, Mode=TwoWay}" />
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.Column="1" IsVisible="{Binding HasSelectedRule}" Spacing="8">
            <TextBlock Text="Selected rule" FontWeight="SemiBold" />
            <TextBlock Text="{Binding SelectedRule.Name}" />
            <TextBlock Text="{Binding SelectedRule.Id}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Enable or disable" Command="{Binding ToggleSelectedRuleCommand}" />
                <Button Content="Delete" Command="{Binding DeleteSelectedRuleCommand}" />
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
