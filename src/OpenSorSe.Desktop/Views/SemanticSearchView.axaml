<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             xmlns:semantic="using:OpenSorSe.Application.Semantic"
             xmlns:views="using:OpenSorSe.Desktop.Views"
             x:Class="OpenSorSe.Desktop.Views.SemanticSearchView"
             x:DataType="vm:SemanticSearchViewModel">
    <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <StackPanel Spacing="3">
                <TextBlock Text="Semantic Search" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Beta — local deterministic hybrid search, not production-grade semantic understanding."
                           TextWrapping="Wrap" />
                <TextBlock Text="Indexes application-owned metadata and bounded extracted text locally. It does not require AI and never sends content to Ollama."
                           TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1" Content="Help" Command="{Binding HelpCommand}" />
        </Grid>
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <TextBox Text="{Binding QueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="For example: tax documents from 2023"
                     AutomationProperties.Name="Semantic search query" />
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}" />
            <Button Grid.Column="2" Content="Clear query" Command="{Binding ClearQueryCommand}" />
        </Grid>
        <StackPanel Grid.Row="2" Spacing="7">
            <WrapPanel>
                <Button Margin="0,0,8,8" Content="Refresh index" Command="{Binding BuildIndexCommand}" />
                <Button Margin="0,0,8,8" Content="Rebuild index" Command="{Binding RebuildIndexCommand}" />
                <Button Margin="0,0,8,8" IsVisible="{Binding IsBusy}" Content="Cancel" Command="{Binding CancelCommand}" />
                <Button Margin="0,0,8,8" Content="Clear index" Command="{Binding RequestClearIndexCommand}" />
                <Button Margin="0,0,8,8" IsVisible="{Binding IsClearPending}" Content="Confirm clear" Command="{Binding ConfirmClearIndexCommand}" />
                <Button Margin="0,0,8,8" IsVisible="{Binding IsClearPending}" Content="Keep index" Command="{Binding CancelClearIndexCommand}" />
            </WrapPanel>
            <ProgressBar Minimum="0" Maximum="1" Value="{Binding ProgressValue}" IsVisible="{Binding IsBusy}" />
            <TextBlock Text="{Binding ProgressText}" TextWrapping="Wrap" />
            <views:StatusBanner DataContext="{Binding Status}" />
        </StackPanel>
        <Border Grid.Row="3"
                Padding="12"
                BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                BorderThickness="1">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Hits}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="semantic:SemanticSearchHit">
                            <Border Padding="0,8"
                                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                                    BorderThickness="0,1,0,0">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding FullPath}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Score, StringFormat=Hybrid score: {0:F1}}" />
                                    <TextBlock Text="{Binding Explanation}" TextWrapping="Wrap" />
                                    <WrapPanel>
                                        <Button Margin="0,0,8,0"
                                                Content="Open file"
                                                Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                x:CompileBindings="False" />
                                        <Button Content="Open containing folder"
                                                Command="{Binding DataContext.OpenContainingFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                x:CompileBindings="False" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
