<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12">
            <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="Application logging" FontSize="18" FontWeight="SemiBold" />
            <StackPanel Spacing="4">
                <CheckBox Content="Enable local daily diagnostic logging" IsChecked="{Binding Draft.FileLoggingEnabled, Mode=TwoWay}" />
                <TextBlock Text="Writes OpenSorSe application diagnostics to its local log folder. This does not read or change scanned user files."
                           TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="Diagnostic log folder" FontWeight="SemiBold" />
                <TextBlock Text="Optional absolute folder for OpenSorSe application log files. Leave empty to use the default local application-data folder."
                           TextWrapping="Wrap" />
                <TextBox PlaceholderText="Optional absolute log directory" Text="{Binding Draft.LogDirectoryPath, Mode=TwoWay}" />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding DailyLogRetentionLabel}" FontWeight="SemiBold" />
                <TextBlock Text="{Binding DailyLogRetentionDescription}" TextWrapping="Wrap" />
                <TextBox PlaceholderText="At least 1" Text="{Binding Draft.RetainedFileCount, Mode=TwoWay}" />
                <TextBlock Text="{Binding DailyLogRetentionValidation}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Spacing="4">
                <TextBlock Text="Minimum diagnostic detail level" FontWeight="SemiBold" />
                <TextBlock Text="Controls the least severe OpenSorSe application events recorded in diagnostic logs."
                           TextWrapping="Wrap" />
                <ComboBox ItemsSource="{Binding AvailableLogLevels}" SelectedItem="{Binding Draft.MinimumLogLevel, Mode=TwoWay}" />
            </StackPanel>
            <Border Padding="12" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Optional local AI (Ollama)" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox Content="Enable optional AI-assisted suggestions"
                              IsChecked="{Binding Draft.AiEnabled, Mode=TwoWay}" />
                    <TextBlock Text="AI remains optional. Scanning, results, duplicates, diagnostics, and ranked search continue to work when it is disabled or unavailable. Suggestions never rename, move, delete, or create files or folders."
                               TextWrapping="Wrap" />
                    <StackPanel Spacing="4">
                        <TextBlock Text="Ollama endpoint" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Draft.AiEndpoint, Mode=TwoWay}" ToolTip.Tip="Default: http://127.0.0.1:11434" />
                        <TextBlock Text="The default endpoint is local. A custom remote endpoint can receive the filenames, extensions, categories, selected folder names, and concise approved preferences supplied for a request. OpenSorSe does not upload file contents."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Request timeout (seconds)" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Draft.AiRequestTimeoutSeconds, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="4">
                        <TextBlock Text="Installed model" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding AvailableAiModels}"
                                  SelectedItem="{Binding Draft.SelectedAiModel, Mode=TwoWay}" />
                        <TextBlock Text="Use Discover models to populate this list, then save the selected model." TextWrapping="Wrap" />
                    </StackPanel>
                    <CheckBox Content="Use locally recorded review decisions to provide concise preference context"
                              IsChecked="{Binding Draft.PreferenceAdaptationEnabled, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Test connection" Command="{Binding TestAiConnectionCommand}" />
                        <Button Content="Discover models" Command="{Binding DiscoverAiModelsCommand}" />
                        <Button Content="Reset local decision history" Command="{Binding ResetPreferenceHistoryCommand}" />
                    </StackPanel>
                    <TextBlock Text="{Binding AiStatusText}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <TextBlock Text="Restart required after saving to apply active logging changes."
                       IsVisible="{Binding RestartRequired}" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Restore defaults" Command="{Binding RestoreDefaultsCommand}" />
                <Button Content="Discard changes" Command="{Binding CancelCommand}" />
                <Button Content="Save" Command="{Binding SaveCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
