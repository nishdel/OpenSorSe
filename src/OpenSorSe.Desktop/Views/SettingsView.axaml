<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             xmlns:views="using:OpenSorSe.Desktop.Views"
             x:Class="OpenSorSe.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <ScrollViewer x:Name="SettingsScrollViewer">
        <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold" />
                <Button Grid.Column="1"
                        Content="Help"
                        Command="{Binding HelpCommand}"
                        ToolTip.Tip="Open Settings help"
                        AutomationProperties.Name="Help for Settings" />
            </Grid>

            <Border Padding="12" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="General settings" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox Content="Keep bounded completed scan snapshots locally"
                              IsChecked="{Binding Draft.CatalogEnabled, Mode=TwoWay}" />
                    <TextBlock Text="Off by default. Saved snapshots contain display-safe metadata and accepted tags in OpenSorSe application data; selected files are never changed."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Padding="12" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
                <StackPanel Spacing="7">
                    <TextBlock Text="Semantic Search (Beta)" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox Content="Enable local Semantic Search Beta"
                              IsChecked="{Binding Draft.SemanticSearchEnabled, Mode=TwoWay}" />
                    <TextBlock Text="Off by default. Uses a deterministic local feature-hashing index over filenames, confirmed and suggested tags, metadata, native text, and bounded OCR text. It does not require AI and never sends content to a model."
                               TextWrapping="Wrap" />
                    <Grid IsVisible="{Binding IsAdvancedSettingsVisible}"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="8">
                        <StackPanel Spacing="3">
                            <TextBlock Text="Maximum indexed documents" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Draft.MaximumSemanticDocuments, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="Maximum displayed results" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Draft.MaximumSemanticResults, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Padding="12" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Local content and OCR (Beta)" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox Content="Extract bounded document metadata and native text"
                              IsChecked="{Binding Draft.MetadataExtractionEnabled, Mode=TwoWay}" />
                    <CheckBox Content="Enable local OCR"
                              IsChecked="{Binding Draft.OcrEnabled, Mode=TwoWay}" />
                    <CheckBox Content="OCR only when reliable native text is unavailable"
                              IsChecked="{Binding Draft.OcrOnlyWhenNativeTextUnavailable, Mode=TwoWay}" />
                    <TextBlock Text="OCR is off by default, remains local, and never writes recognized text into source documents. Image OCR requires an externally managed Tesseract CLI; scanned-PDF OCR also requires a compatible local rasterizer and is reported unavailable when none exists."
                               TextWrapping="Wrap" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                        <StackPanel Spacing="3">
                            <TextBlock Text="Maximum pages per document" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Draft.MaximumOcrPages, Mode=TwoWay}"
                                     AutomationProperties.Name="Maximum OCR pages" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="Maximum file size (MiB)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Draft.MaximumContentFileSizeMiB, Mode=TwoWay}"
                                     AutomationProperties.Name="Maximum content file size" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Spacing="3">
                            <TextBlock Text="OCR language" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Draft.OcrLanguage, Mode=TwoWay}"
                                     AutomationProperties.Name="OCR language" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="3">
                            <TextBlock Text="Maximum OCR duration (seconds)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Draft.MaximumOcrDurationSeconds, Mode=TwoWay}"
                                     AutomationProperties.Name="Maximum OCR duration" />
                        </StackPanel>
                        <CheckBox Grid.Row="2"
                                  Grid.ColumnSpan="2"
                                  IsVisible="{Binding IsAdvancedSettingsVisible}"
                                  Content="Allow bounded content processing in the background"
                                  IsChecked="{Binding Draft.BackgroundContentProcessingEnabled, Mode=TwoWay}" />
                    </Grid>
                    <WrapPanel>
                        <Button Margin="0,0,8,8"
                                Content="Check local OCR capability"
                                Command="{Binding CheckOcrCapabilityCommand}" />
                        <Button Margin="0,0,8,8"
                                Content="Clear cache / reprocess next scan"
                                Command="{Binding RequestContentCacheResetCommand}" />
                        <Button Margin="0,0,8,8"
                                IsVisible="{Binding IsContentCacheResetPending}"
                                Content="Confirm clear"
                                Command="{Binding ConfirmContentCacheResetCommand}" />
                        <Button Margin="0,0,8,8"
                                IsVisible="{Binding IsContentCacheResetPending}"
                                Content="Cancel"
                                Command="{Binding CancelContentCacheResetCommand}" />
                    </WrapPanel>
                    <views:StatusBanner DataContext="{Binding ContentStatus}" />
                </StackPanel>
            </Border>

            <Border Padding="12" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Optional AI assistance" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox Content="Enable AI features"
                              IsChecked="{Binding Draft.AiEnabled, Mode=TwoWay}" />
                    <TextBlock Text="Off by default. When disabled, OpenSorSe hides AI actions and does not check Ollama, discover models, or send model requests."
                               TextWrapping="Wrap" />

                    <StackPanel IsVisible="{Binding IsAiCapabilitySettingsVisible}" Spacing="8">
                        <TextBlock Text="AI setup" FontWeight="SemiBold" />
                        <TextBlock Text="Ollama is externally managed. The default endpoint is local. A custom endpoint receives the bounded filename metadata described below."
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Ollama endpoint" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Draft.AiEndpoint, Mode=TwoWay}"
                                 ToolTip.Tip="Default: http://127.0.0.1:11434"
                                 AutomationProperties.Name="Ollama endpoint" />

                        <WrapPanel>
                            <Button Margin="0,0,8,8" Content="Check connection" Command="{Binding TestAiConnectionCommand}" />
                            <Button Margin="0,0,8,8" Content="Discover / refresh models" Command="{Binding DiscoverAiModelsCommand}" />
                            <Button Margin="0,0,8,8" IsVisible="{Binding IsAiBusy}" Content="Cancel AI operation" Command="{Binding CancelAiOperationCommand}" />
                        </WrapPanel>
                        <views:StatusBanner DataContext="{Binding AiStatus}" />

                        <TextBlock Text="Installed model" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding AvailableAiModels}"
                                  SelectedItem="{Binding Draft.SelectedAiModel, Mode=TwoWay}"
                                  PlaceholderText="Discover models, then select one"
                                  AutomationProperties.Name="Installed Ollama model" />
                        <TextBlock IsVisible="{Binding HasNoDiscoveredModels}"
                                   Text="No installed models have been discovered yet. Install a model in Ollama, then refresh models."
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding SelectedModelStatusText}" TextWrapping="Wrap" />

                        <TextBlock Text="Request timeout (seconds)" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Draft.AiRequestTimeoutText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="AI request timeout in seconds" />
                        <TextBlock Text="{Binding AiRequestTimeoutValidation}" TextWrapping="Wrap" />

                        <TextBlock Text="AI capabilities" FontWeight="SemiBold" />
                        <CheckBox Content="Enable file rename suggestions"
                                  IsChecked="{Binding Draft.FileRenameSuggestionsEnabled, Mode=TwoWay}" />
                        <CheckBox Content="Enable folder structure suggestions"
                                  IsChecked="{Binding Draft.FolderStructureSuggestionsEnabled, Mode=TwoWay}" />
                        <TextBlock Text="Suggestions are unverified review-only proposals. Exact filenames and bounded metadata may be sent; file contents are never sent, and no suggestion changes a file or folder."
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding AiSetupReadinessText}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Padding="12" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="Interface complexity" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox Content="Show advanced features"
                              IsChecked="{Binding Draft.ShowAdvancedFeatures, Mode=TwoWay}" />
                    <TextBlock Text="Shows specialist comparison, diagnostics, operation-history, logging, AI request diagnostics, and troubleshooting controls. Hidden values remain saved."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsAdvancedSettingsVisible}"
                    Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Advanced diagnostics and logging" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox Content="Enable local daily diagnostic logging" IsChecked="{Binding Draft.FileLoggingEnabled, Mode=TwoWay}" />
                    <TextBlock Text="Diagnostic log folder" FontWeight="SemiBold" />
                    <TextBox PlaceholderText="Optional absolute log directory" Text="{Binding Draft.LogDirectoryPath, Mode=TwoWay}" />
                    <TextBlock Text="{Binding DailyLogRetentionLabel}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DailyLogRetentionDescription}" TextWrapping="Wrap" />
                    <TextBox PlaceholderText="At least 1" Text="{Binding Draft.RetainedFileCount, Mode=TwoWay}" />
                    <TextBlock Text="{Binding DailyLogRetentionValidation}" TextWrapping="Wrap" />
                    <TextBlock Text="Minimum diagnostic detail level" FontWeight="SemiBold" />
                    <ComboBox ItemsSource="{Binding AvailableLogLevels}" SelectedItem="{Binding Draft.MinimumLogLevel, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border IsVisible="{Binding IsAdvancedAiSettingsVisible}"
                    Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Advanced AI diagnostics" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox Content="Enable AI request diagnostics"
                              IsChecked="{Binding Draft.AiRequestDiagnosticsEnabled, Mode=TwoWay}" />
                    <TextBlock Text="AI request diagnostics may contain filenames and relative folder metadata. When enabled, the latest 20 requests may retain redacted prompts and responses in memory for this session only. Disabling and saving clears them."
                               TextWrapping="Wrap" />
                    <CheckBox Content="Use locally recorded review decisions as concise preference context"
                              IsChecked="{Binding Draft.PreferenceAdaptationEnabled, Mode=TwoWay}" />
                    <WrapPanel>
                        <Button Margin="0,0,8,8" Content="Reset local decision history" Command="{Binding RequestPreferenceHistoryResetCommand}" />
                        <Button Margin="0,0,8,8" IsVisible="{Binding IsPreferenceHistoryResetPending}" Content="Confirm decision-history reset" Command="{Binding ConfirmPreferenceHistoryResetCommand}" />
                        <Button Margin="0,0,8,8" IsVisible="{Binding IsPreferenceHistoryResetPending}" Content="Cancel reset" Command="{Binding CancelPreferenceHistoryResetCommand}" />
                    </WrapPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="Restart required only to apply active logging changes."
                       IsVisible="{Binding RestartRequired}"
                       TextWrapping="Wrap" />
            <WrapPanel>
                <Button Margin="0,0,8,8" Content="Restore defaults" Command="{Binding RestoreDefaultsCommand}" />
                <Button Margin="0,0,8,8" Content="Discard changes" Command="{Binding CancelCommand}" />
                <Button Margin="0,0,8,8" Content="Save" Command="{Binding SaveCommand}" />
            </WrapPanel>
            <views:StatusBanner DataContext="{Binding Status}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
