<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.StatusBanner"
             x:DataType="vm:StatusPresentation">
    <Border Padding="10"
            CornerRadius="4"
            BorderBrush="{DynamicResource ThemeBorderMidBrush}"
            BorderThickness="1"
            Background="{DynamicResource ThemeControlLowBrush}"
            AutomationProperties.Name="{Binding AccessibleText}">
        <StackPanel Spacing="3">
            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
            <Expander Header="Technical details"
                      IsVisible="{Binding HasTechnicalDetails}">
                <TextBlock Text="{Binding TechnicalDetails}"
                           TextWrapping="Wrap"
                           FontFamily="Consolas" />
            </Expander>
        </StackPanel>
    </Border>
</UserControl>
