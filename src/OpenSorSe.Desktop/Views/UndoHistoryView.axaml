<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenSorSe.Desktop.ViewModels"
             x:Class="OpenSorSe.Desktop.Views.UndoHistoryView"
             x:DataType="vm:UndoHistoryViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock Text="Operation history" FontSize="24" FontWeight="SemiBold" />
                <Button Grid.Column="1" Content="Help" Command="{Binding HelpCommand}"
                        ToolTip.Tip="Open Operation history help" AutomationProperties.Name="Help for Operation history" />
            </Grid>
            <TextBlock Text="This page lists completed file operations when a future execution workflow supplies them."
                       TextWrapping="Wrap" />
            <Border IsVisible="{Binding IsEmpty}"
                    Padding="12"
                    BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                    BorderThickness="1">
                <TextBlock Text="{Binding EmptyStateMessage}" TextWrapping="Wrap" />
            </Border>
            <StackPanel IsVisible="{Binding HasSessions}" Spacing="8">
                <TextBlock Text="Operation-history sessions supplied for this application process" TextWrapping="Wrap" />
                <ListBox ItemsSource="{Binding Sessions}" SelectedItem="{Binding SelectedSession, Mode=TwoWay}" />
                <TextBlock Text="{Binding SelectedSession.SessionId}" />
                <TextBlock Text="{Binding SelectedSession.Records.Count, StringFormat='Operation records: {0}'}" />
            </StackPanel>
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
