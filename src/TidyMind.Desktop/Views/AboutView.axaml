<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TidyMind.Desktop.ViewModels"
             x:Class="TidyMind.Desktop.Views.AboutView"
             x:DataType="vm:AboutViewModel">
    <StackPanel Spacing="12">
        <TextBlock Text="{Binding ApplicationName}" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Text="{Binding Version}" />
        <TextBlock Text="{Binding License}" />
        <TextBlock Text="{Binding Acknowledgements}" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Project repository" Command="{Binding OpenRepositoryCommand}" />
            <Button Content="Documentation" Command="{Binding OpenDocumentationCommand}" />
        </StackPanel>
    </StackPanel>
</UserControl>
