<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TidyMind.Desktop.ViewModels"
             x:Class="TidyMind.Desktop.Views.RuleEditorView"
             x:DataType="vm:RuleEditorViewModel">
    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,*,Auto" ColumnSpacing="16" RowSpacing="12">
        <TextBlock Grid.ColumnSpan="2" Text="Rule Editor" FontSize="24" FontWeight="SemiBold" />
        <StackPanel Grid.Row="1" Spacing="6">
            <TextBlock Text="Current rules" FontWeight="SemiBold" />
            <ListBox ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule, Mode=TwoWay}" />
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="8">
            <TextBlock Text="Selected rule" FontWeight="SemiBold" />
            <TextBlock Text="{Binding SelectedRule.Name}" />
            <TextBlock Text="{Binding SelectedRule.Id}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Enable or disable" Command="{Binding ToggleSelectedRuleCommand}" />
                <Button Content="Delete" Command="{Binding DeleteSelectedRuleCommand}" />
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
            <Button Content="Save" Command="{Binding SaveCommand}" />
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
