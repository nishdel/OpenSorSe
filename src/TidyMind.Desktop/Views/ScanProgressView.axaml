<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TidyMind.Desktop.ViewModels"
             x:Class="TidyMind.Desktop.Views.ScanProgressView"
             x:DataType="vm:ScanProgressViewModel">
    <StackPanel Spacing="12">
        <TextBlock Text="Scanning" FontSize="24" FontWeight="SemiBold" />
        <ProgressBar IsIndeterminate="{Binding IsActive}" Height="12" />
        <TextBlock Text="{Binding StatusText}" />
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="6">
            <TextBlock Grid.Row="0" Text="Current folder" FontWeight="SemiBold" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentFolder}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="1" Text="Files found" FontWeight="SemiBold" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FilesFound}" />
            <TextBlock Grid.Row="2" Text="Folders scanned" FontWeight="SemiBold" />
            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding FoldersScanned}" />
            <TextBlock Grid.Row="3" Text="Elapsed" FontWeight="SemiBold" />
            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Elapsed}" />
        </Grid>
        <Button Content="Cancel scan" IsEnabled="{Binding IsActive}" Click="OnCancelClick" HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
